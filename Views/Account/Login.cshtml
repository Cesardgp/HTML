@model Users

<h2>Iniciar Sesión</h2>

<form asp-action="Login" method="post">

    <div>
        <label>Usuario</label>
        <input asp-for="Usuario" />
    </div>

    <div>
        <label>Contraseña</label>
        <input asp-for="Contraseña" type="password" />
    </div>

    <button type="submit">
        Ingresar
    </button>
    <button type="button"
            class="btn btn-secondary"
            onclick="location.href='@Url.Action("Register", "Account")'">
        Registrarse
    </button>

</form>

@if (ViewBag.Error != null)
{
    <p>@ViewBag.Error</p>
}